@{

    Layout = "~/Views/Shared/_LandingLayout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    .hero-banner {
        
        padding: 120px 20px;
        color: white;
        position: relative;
        text-align: center;
    }

        .hero-banner::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.6);
            z-index: 0;
        }

        .hero-banner h1,
        .hero-banner p {
            position: relative;
            z-index: 1;
        }

    .about-img {
        width: 100%;
        height: auto;
        border-radius: 10px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }

    .section-title {
        font-weight: bold;
        margin-bottom: 1rem;
    }

    .highlight-list li {
        margin-bottom: 10px;
    }
</style>


<!-- HERO CAROUSEL -->
<section id="home">
    <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="~/images/background.jpg" class="d-block w-100" style="height: 80vh; object-fit: cover;" />
                <div class="carousel-caption d-none d-md-block">
                    <h1 class="text-white">About Beta Library</h1>
                    <p class="lead text-white">Empowering knowledge, innovation, and research since 2018</p>
                </div>
            </div>
            <div class="carousel-item">
                <img src="~/images/book.jpg" class="d-block w-100" style="height: 80vh; object-fit: cover;" />
                <div class="carousel-caption d-none d-md-block">
                    <h1 class="text-white">Knowledge at Your Fingertips</h1>
                    <p class="lead text-white">Search, borrow, and learn with ease</p>
                </div>
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>
</section>


<!-- MISSION & VISION -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="row align-items-center g-5">
            
            <div class="col-lg-6">
                <h2 class="section-title">Our Mission</h2>
                <p>
                    To provide inclusive, accessible, and tech-driven learning resources to students, educators, and researchers through a supportive and efficient library system.
                </p>
                <h3 class="mt-4 fw-semibold">Our Vision</h3>
                <p>
                    To be a regional leader in digital and physical library services — inspiring lifelong learning, collaboration, and academic excellence.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- WHAT WE OFFER -->
<section class="py-5">
    <div class="container">
        <div class="row align-items-center g-5 flex-lg-row-reverse">
            <div class="col-lg-6">
                <img src="~/images/image.jpg" alt="Library Facility" class="about-img" />
            </div>
            <div class="col-lg-6">
                <h2 class="section-title">📚 What We Offer</h2>
                <ul class="list-unstyled highlight-list ps-3 d-block">
                    <li class="mb-2 d-block">📘 Thousands of books in all fields</li>
                    <li class="mb-2 d-block">💻 Digital borrowing & return system</li>
                    <li class="mb-2 d-block">📄 Access to academic past papers</li>
                    <li class="mb-2 d-block">📚 Silent and group study zones</li>
                    <li class="mb-2 d-block">📶 Reliable Wi-Fi and tech resources</li>
                    <li class="mb-2 d-block">🔍 Professional research assistance</li>
                </ul>


            </div>
        </div>
    </div>
</section>

<!-- WHY CHOOSE US -->
<section class="py-5 bg-light">
    <div class="container text-center">
        <h2 class="section-title"> Why Choose Beta Library</h2>
        <p class="text-muted mx-auto" style="max-width: 750px;">
            We bridge the gap between technology and traditional learning.
            Whether you’re accessing a digital resource from home or flipping through a physical book in our reading area,
            Beta Library is here to make your learning journey smooth, productive, and enjoyable.
        </p>
    </div>
</section>
