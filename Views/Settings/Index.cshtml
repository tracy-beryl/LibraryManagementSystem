@model LibraryManagementSystem.Models.Settings

@{
    ViewData["Title"] = "Institution Settings";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-center">
        <div class="card shadow w-100" style="max-width: 600px;">
            <div class="card-header bg-dark text-white text-center">
                <h4 class="mb-0">Institution Settings</h4>
            </div>

            <div class="card-body">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">
                        @TempData["Success"]
                    </div>
                }

                <form asp-action="Index" asp-controller="Settings" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Institution Name</label>
                        <input asp-for="Name" class="form-control" placeholder="Enter institution name" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ShortCode" class="form-label">Short Code</label>
                        <input asp-for="ShortCode" class="form-control" placeholder="Enter short code e.g. BUMBE" />
                        <span asp-validation-for="ShortCode" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Upload Logo</label>
                        <input type="file" name="formFile" class="form-control" accept="image/*" />
                        <small class="text-muted">Choose a new logo only if you want to replace the current one.</small>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model?.LogoPath))
                    {
                        <div class="mb-3">
                            <label class="form-label d-block">Current Logo</label>
                            <img src="~/images/@Model.LogoPath"
                                 alt="Institution Logo"
                                 class="img-thumbnail"
                                 style="max-height: 120px;" />
                        </div>
                    }

                    <div class="d-flex justify-content-between">
                        <button type="submit" class="btn btn-dark">Save Settings</button>
                        <a asp-action="Index" asp-controller="Settings" class="btn btn-outline-secondary">Refresh</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}