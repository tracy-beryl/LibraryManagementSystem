@model LibraryManagementSystem.Models.Settings

@{
    ViewData["Title"] = "Institution Settings";
}

<div class="d-flex justify-content-center align-items-center px-3" style="min-height: 100vh; background-color: #f8f9fa;">
    <div class="card shadow w-100" style="max-width: 500px;">
        <div class="card-header bg-dark text-white text-center">
            <h4 class="mb-0">Add Institutional Settings</h4>
        </div>

        <div class="card-body">
            <form asp-action="Index" asp-controller="Settings" method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ShortCode" class="form-label"></label>
                    <input asp-for="ShortCode" class="form-control" />
                    <span asp-validation-for="ShortCode" class="text-danger"></span>
                </div>



                <div class="mb-3">
                    <label asp-for="LogoPath" class="custom-label">Upload Logo</label>
                    <div class="custom-file">
                        <input asp-for="LogoPath" type="file" name="formFile" class="form-control custom-file-input" />

                    </div>
                </div>

                <div class="d-flex justify-content-between">
                    <button type="submit" class="btn btn-dark">Save</button>
                </div>

            </form>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        $(document).ready(function () {
            $('.custom-file-input').on("change", function () {
                var fileName = $(this).val().split("\\").pop();
                $(this).next('.custom-file-label').html(fileName);
            });
        });
    </script>
}

