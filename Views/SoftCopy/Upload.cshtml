@model LibraryManagementSystem.ViewModels.SoftCopyViewModel

<div class="d-flex justify-content-center align-items-center px-3" style="min-height: 100vh; background-color: #f8f9fa;">
    <div class="card shadow w-100" style="max-width: 500px;">
        <div class="card-header bg-dark text-white text-center">
            <h4 class="mb-0">Add Soft Copy</h4>
        </div>

        <div class="card-body">

            <form asp-action="Upload" method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control"></textarea>
                </div>
                <div class="mb-3">
                    <label asp-for="File" class="form-label"></label>
                    <input asp-for="File" class="form-control" type="file" />
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-dark">Back</a>
                    <button type="submit" class="btn btn-dark">Upload</button>
                </div>



                @section Scripts {
                    <script>
                        $(document).ready(function () {
                            $('.custom-file-input').on("change", function () {
                                var fileName = $(this).val().split("\\").pop();
                                $(this).next('.custom-file-label').html(fileName);
                            });
                        });
                    </script>
                }


            </form>
        </div>


        </div>
</div>