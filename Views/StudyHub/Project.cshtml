@model LibraryManagementSystem.ViewModels.ProjectDetailsViewModel
@using LibraryManagementSystem.Models

@{
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<h3 class="fw-bold">@Model.ProjectName</h3>
<p class="text-muted">@Model.Description</p>

@if (Model.UnreadCount > 0)
{
    <div class="alert alert-info py-2">
        @Model.UnreadCount unread message(s)
    </div>
}

@Html.AntiForgeryToken()

<ul class="nav nav-tabs mt-4">
    <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#team">Team</button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#resources">Resources</button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#deadlines">Deadlines</button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#chat">Chat</button>
    </li>
</ul>

<div class="tab-content mt-3">

    <!-- TEAM TAB -->
    <div class="tab-pane fade show active" id="team">

        @if (Model.IsOwner)
        {
            <button class="btn btn-primary mb-3"
                    data-bs-toggle="modal"
                    data-bs-target="#inviteModal">
                Invite Member
            </button>
        }
        <ul class="list-group">
            @foreach (var member in Model.Members)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span>
                        @member.Student.FullName
                        <span class="online-indicator text-success d-none"
                              data-user="@member.StudentId">●</span>
                    </span>
                    <span class="badge bg-primary">@member.Role</span>
                </li>
            }
        </ul>

    </div>

    <!-- RESOURCES TAB -->
    <div class="tab-pane fade" id="resources">

        <!-- Every project member can add -->
        <form asp-action="AddResource" method="post" enctype="multipart/form-data" class="mb-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="projectId" value="@Model.Id" />

            <input name="title" class="form-control mb-2" placeholder="Title" required />

            <select name="type" id="resourceType" class="form-control mb-2">
                <option value="@((int)ResourceType.Document)">Document</option>
                <option value="@((int)ResourceType.WebLink)">Web Link</option>
                <option value="@((int)ResourceType.YouTube)">YouTube</option>
                <option value="@((int)ResourceType.PastPaper)">Past Paper</option>
            </select>

            <div id="fileGroup" class="mb-2">
                <input type="file" name="file" id="resourceFile" class="form-control" />
            </div>

            <div id="urlGroup" class="mb-2 d-none">
                <input type="text" name="url" id="resourceUrl" class="form-control"
                       placeholder="URL (for links and YouTube)" />
            </div>

            <button class="btn btn-success">Add Resource</button>
        </form>

        @foreach (var resource in Model.Resources)
        {
            <div class="card mb-3 p-3">
                <h6>@resource.Title</h6>
                <small class="text-muted">Views: @resource.ViewCount</small>
                <hr />

                @if (resource.Type == ResourceType.Document ||
                    resource.Type == ResourceType.PastPaper)
                {
                    <a href="@resource.FilePath"
                       target="_blank"
                       onclick="trackView(@resource.Id)">
                        Download
                    </a>
                }
                else if (resource.Type == ResourceType.WebLink)
                {
                    <a href="@resource.Url"
                       target="_blank"
                       onclick="trackView(@resource.Id)">
                        Visit Link
                    </a>
                }
                else if (resource.Type == ResourceType.YouTube)
                {
                    var videoId = "";

                    if (!string.IsNullOrEmpty(resource.Url))
                    {
                        if (resource.Url.Contains("v="))
                        {
                            videoId = resource.Url.Split("v=").Last().Split("&")[0];
                        }
                        else
                        {
                            videoId = resource.Url.Split("/").Last();
                        }
                    }

                    <iframe width="100%" height="250"
                            src="https://www.youtube.com/embed/@videoId"
                            frameborder="0"
                            allowfullscreen>
                    </iframe>
                }
            </div>
        }

    </div>

    <!-- DEADLINES TAB -->
    <div class="tab-pane fade" id="deadlines">

        @if (Model.IsOwner)
        {
            <form asp-action="AddDeadline" method="post" class="mb-4">
                @Html.AntiForgeryToken()
                <input type="hidden" name="projectId" value="@Model.Id" />

                <input name="title" class="form-control mb-2" placeholder="Deadline Title" required />
                <input type="date" name="dueDate" class="form-control mb-2" required />

                <button class="btn btn-warning">Add Deadline</button>
            </form>
        }
        @foreach (var deadline in Model.Deadlines)
        {
            var today = DateTime.UtcNow.Date;
            var dueDate = deadline.DueDate.Date;
            var isOverdue = dueDate < today;
            var daysLeft = (dueDate - today).Days;

            <div class="card p-3 mb-3">
                <strong>@deadline.Title</strong>
                <br />
                <small>
                    Due: @deadline.DueDate.ToLocalTime().ToString("dd MMM yyyy")
                </small>
                <br />

                @if (isOverdue)
                {
                    <span class="badge bg-danger">Overdue</span>
                }
                else
                {
                    <span class="badge bg-warning">
                        @daysLeft day(s) left
                    </span>
                }
            </div>
        }

    </div>

    <!-- CHAT TAB -->
    <div class="tab-pane fade" id="chat">

        <div id="chatBox"
             class="border rounded p-3 mb-2"
             style="height:350px; overflow-y:auto; background:#f8f9fa;">

            @foreach (var msg in Model.Messages)
            {
                var isMe = msg.SenderId == currentUserId;

                <div class="mb-2 @(isMe ? "text-end" : "")">
                    <strong>@msg.SenderName:</strong>
                    @msg.Text
                    <br />
                    <small class="text-muted">
                        @msg.SentAt.ToLocalTime().ToString("HH:mm")
                    </small>
                </div>
            }
        </div>

        <div id="typingIndicator" class="text-muted small mb-2 d-none">
            Someone is typing...
        </div>

        <div class="input-group">
            <input type="text"
                   id="messageInput"
                   class="form-control"
                   placeholder="Type a message..." />
            <button class="btn btn-primary" id="sendButton">Send</button>
        </div>

    </div>

</div>

<div class="modal fade" id="inviteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="InviteMember" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="projectId" value="@Model.Id" />

                <div class="modal-header">
                    <h5 class="modal-title">Invite Member</h5>
                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input name="emailOrAdmission"
                           class="form-control"
                           placeholder="Email or Admission Number"
                           required />
                </div>

                <div class="modal-footer">
                    <button type="submit"
                            class="btn btn-success">
                        Invite
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

    function trackView(resourceId) {
        fetch("/StudyHub/TrackResourceView", {
            method: "POST",
            headers: {
                "Content-Type": "application/x-www-form-urlencoded",
                "RequestVerificationToken": token
            },
            body: `resourceId=${resourceId}`
        });
    }
</script>

<script>
    function toggleResourceInput() {
        const resourceType = parseInt(document.getElementById("resourceType").value);
        const fileGroup = document.getElementById("fileGroup");
        const urlGroup = document.getElementById("urlGroup");
        const fileInput = document.getElementById("resourceFile");
        const urlInput = document.getElementById("resourceUrl");

        const isFileType =
            resourceType === @((int)ResourceType.Document) ||
            resourceType === @((int)ResourceType.PastPaper);

        if (isFileType) {
            fileGroup.classList.remove("d-none");
            urlGroup.classList.add("d-none");
            fileInput.disabled = false;
            urlInput.disabled = true;
            urlInput.value = "";
        } else {
            fileGroup.classList.add("d-none");
            urlGroup.classList.remove("d-none");
            fileInput.disabled = true;
            fileInput.value = "";
            urlInput.disabled = false;
        }
    }

    document.addEventListener("DOMContentLoaded", function () {
        const select = document.getElementById("resourceType");
        if (select) {
            select.addEventListener("change", toggleResourceInput);
            toggleResourceInput();
        }
    });
</script>

<script>


const connection = new signalR.HubConnectionBuilder()
    .withUrl("/collaborationHub")
    .withAutomaticReconnect()
    .build();

connection.start()
    .then(() => connection.invoke("JoinProjectGroup", "@Model.Id"))
    .catch(err => console.error(err));

connection.on("ReceiveMessage", function (senderId, senderName, message, sentAt) {
    appendMessage(senderId, senderName, message, sentAt);
    markAsRead();
});

connection.on("UserOnline", function (userId) {
    const el = document.querySelector(`[data-user='${userId}']`);
    if (el) el.classList.remove("d-none");
});

connection.on("UserOffline", function (userId) {
    const el = document.querySelector(`[data-user='${userId}']`);
    if (el) el.classList.add("d-none");
});

connection.on("UserTyping", function (userId) {
    if (userId === "@currentUserId") return;

    const indicator = document.getElementById("typingIndicator");
    indicator.classList.remove("d-none");

    clearTimeout(window.typingTimeout);
    window.typingTimeout = setTimeout(() => {
        indicator.classList.add("d-none");
    }, 2000);
});

function appendMessage(senderId, senderName, message, sentAt) {

    const chatBox = document.getElementById("chatBox");
    const div = document.createElement("div");
    div.classList.add("mb-2");

    if (senderId === "@currentUserId") {
        div.classList.add("text-end");
    }

    div.innerHTML =
        `<strong>${senderName}:</strong> ${message}<br/>
         <small class="text-muted">
         ${new Date(sentAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
         </small>`;

    chatBox.appendChild(div);
    chatBox.scrollTop = chatBox.scrollHeight;
}

const sendButton = document.getElementById("sendButton");
const messageInput = document.getElementById("messageInput");

sendButton.addEventListener("click", sendMessage);

messageInput.addEventListener("keypress", function (e) {
    if (e.key === "Enter") {
        sendMessage();
    } else {
        connection.invoke("Typing", "@Model.Id");
    }
});

function sendMessage() {

    const message = messageInput.value.trim();
    if (!message) return;

    fetch("/StudyHub/SendMessage", {
        method: "POST",
        headers: {
            "Content-Type": "application/x-www-form-urlencoded",
            "RequestVerificationToken": token
        },
        body: `projectId=@Model.Id&message=${encodeURIComponent(message)}`
    })
    .then(res => {
        if (!res.ok) throw new Error();
        messageInput.value = "";
    })
    .catch(() => alert("Message failed to send."));
}

function markAsRead() {
    fetch("/StudyHub/MarkAsRead", {
        method: "POST",
        headers: {
            "Content-Type": "application/x-www-form-urlencoded",
            "RequestVerificationToken": token
        },
        body: `projectId=@Model.Id`
    });
}

// mark as read on load
    markAsRead();

    fetch('/StudyHub/GetPendingInvitationCount')
        .then(res => {
            if (!res.ok) return null;
            return res.json();
        })
        .then(data => {
            if (!data) return;
            // use data safely
        });
</script>