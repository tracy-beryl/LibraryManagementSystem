@model LibraryManagementSystem.ViewModels.PastPaperZipImportViewModel

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm rounded-3">
                <div class="card-header bg-dark text-white">
                    <h4 class="mb-0">Import Past Papers from ZIP + Excel</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Import" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="form-group mb-3">
                            <label asp-for="ZipFile">ZIP File</label>
                            <input asp-for="ZipFile" type="file" class="form-control" accept=".zip" />
                            <span asp-validation-for="ZipFile" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="ExcelFile">Excel File (.xlsx)</label>
                            <input asp-for="ExcelFile" type="file" class="form-control" accept=".xlsx" />
                            <span asp-validation-for="ExcelFile" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-dark">Import</button>
                    </form>

                    <hr />

                    <h6>Expected Excel Columns</h6>
                    <ol>
                        <li>FileName</li>
                        <li>CourseCode</li>
                        <li>CourseTitle</li>
                        <li>AcademicYear</li>
                        <li>Semester</li>
                        <li>Category</li>
                    </ol>

                    <p class="text-muted mb-0">
                        Category values must match: ResearchPaper, KNEC, KASNEB, or CDACC.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>