@model LibraryManagementSystem.ViewModels.PastPapersViewModel


    <div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm rounded-3">
                <div class="card-header bg-dark text-white">
                    <h4 class="mb-0">Add a PastPaper</h4>
                </div>
                <div class="card-body">
                    <form asp-action="PastPapers" method="post" enctype="multipart/form-data" class="mb-4">
                        <div class="form-group">
                            <label>Course Code</label>
                            <input asp-for="CourseCode" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Course Title</label>
                            <input asp-for="CourseTitle" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Academic Year</label>
                            <input asp-for="AcademicYear" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Semester</label>
                            <input asp-for="Semester" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Upload File</label>
                            <input asp-for="File" type="file" class="form-control" />
                        </div>
                        <button type="submit" class="btn btn-dark mt-2">Upload</button>
                    </form>


                </div>
            </div>
        </div>
    </div>
    </div>