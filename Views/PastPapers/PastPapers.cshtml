@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@model IEnumerable<LibraryManagementSystem.Models.PastPapers>


<div class="container-md" style="margin-right:7px">

    <h2>Uploaded Past Papers</h2>
    <a asp-action="Create" asp-controller="PastPapers">Create</a>

    <table id="example" class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Course Code</th>
                <th>Course Title</th>
                <th>Academic Year</th>
                <th>Semester</th>
                <th>Uploaded By</th>
                <th>View</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var paper in Model)
            {
                <tr>
                    <td>@paper.CourseCode</td>
                    <td>@paper.CourseTitle</td>
                    <td>@paper.AcademicYear</td>
                    <td>@paper.Semester</td>
                    <td>@paper.UploadedBy</td>
                    <td><a href="@paper.FilePath" target="_blank">View</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script>
    new DataTable('#example');
</script>
