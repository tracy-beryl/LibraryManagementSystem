@using Microsoft.AspNetCore.Identity
@model LibraryManagementSystem.ViewModels.BookViewModel;
@inject LibraryManagementSystem.Service.MyService service;
@inject UserManager<LibraryManagementSystem.Models.ApplicationUser> user;


@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}



@{
    var loggedIdUser = await user.GetUserAsync(User);
    var isStudent = false;
    if (loggedIdUser != null)
    {
        isStudent = await service.IsStudent(loggedIdUser.Id);

        var name = loggedIdUser.Email;
    }
}

<div class="container-fluid px-3">
    <h2>Books</h2>

    @if (!isStudent)
    {
        <div class="d-flex flex-wrap justify-content-end gap-2 mb-3">
            <a asp-action="Create" asp-controller="Book" class="btn btn-outline-dark btn-sm">Create</a>
            <button type="button" class="btn btn-dark btn-sm" data-bs-toggle="modal" data-bs-target="#borrowBooks">
                Borrow
            </button>
        </div>
    }


    <div class="table-responsive">
        <table id="example" class="table table-bordered table-striped align-middle">
            <thead class="table-dark">
                <tr>
                    <th>No</th>
                    <th>Title</th>
                    <th>Author</th>
                    <th>ISBN</th>
                    <th>Total Copies</th>
                    <th>Available Copies</th>
                    <th>Category</th>
                    <th>Book Cover</th>
                    <th>Borrowing Days</th>

                    @if (!isStudent)
                    {
                        <th colspan="2">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @{
                    int count = 1;
                }
                @foreach (var item in Model.AllBooks)
                {
                    <tr>
                        <td>@count</td>
                        <td>@item.Title</td>
                        <td>@item.Author</td>
                        <td>@item.ISBN</td>
                        <td>@item.TotalCopies</td>
                        <td>@item.AvailableCopies</td>
                        <td>@item.Category</td>
                        <td>
                            <img src="/images/@item.PhotoPath" alt="Book Cover" class="img-fluid rounded" style="max-height: 100px;" />
                        </td>
                        <td>@item.BorrowingDays</td>


                        @if (!isStudent)
                        {
                            <td>
                                <button type="button" class="btn btn-sm btn-dark details-button"
                                        data-bs-toggle="modal" data-bs-target="#detailsModal"
                                        data-id="@item.Id"
                                        data-title="@item.Title"
                                        data-author="@item.Author"
                                        data-isbn="@item.ISBN"
                                        data-totalcopies="@item.TotalCopies"
                                        data-availablecopies="@item.AvailableCopies"
                                        data-category="@item.Category"
                                        data-borrowingdays="@item.BorrowingDays"
                                        data-photopath="@item.PhotoPath">
                                    Details
                                </button>
                            </td>
                            <td>
                                <button type="button" class="btn btn-sm btn-dark edit-button"
                                        data-bs-toggle="modal" data-bs-target="#editModal"
                                        data-id="@item.Id"
                                        data-title="@item.Title"
                                        data-author="@item.Author"
                                        data-isbn="@item.ISBN"
                                        data-totalcopies="@item.TotalCopies"
                                        data-availablecopies="@item.AvailableCopies"
                                        data-category="@item.Category"
                                        data-borrowingdays="@item.BorrowingDays"
                                        data-photopath="@item.PhotoPath">
                                    Edit
                                </button>
                            </td>
                        }
                    </tr>
                    count++;
                }
            </tbody>
        </table>
    </div>


    <div class="modal fade" id="detailsModal" tabindex="-1" aria-labelledby="detailsModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">

            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title" id="detailsModalLabel">Book Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>

                </div>

                <div class="modal-body">
                    <table class="table table-bordered">
                        <tr><th>Title</th><td id="detail-title"></td></tr>
                        <tr><th>Author</th><td id="detail-author"></td></tr>
                        <tr><th>ISBN</th><td id="detail-isbn"></td></tr>
                        <tr><th>Total Copies</th><td id="detail-totalcopies"></td></tr>
                        <tr><th>Available Copies</th><td id="detail-availablecopies"></td></tr>
                        <tr><th>Category</th><td id="detail-category"></td></tr>
                        <tr><th>Borrowing Days</th><td id="detail-borrowingdays"></td></tr>
                        <tr>
                            <th>Photo</th>
                            <td>
                                <img id="detail-photo" src="/images/alt-image.jpg" alt="Book Image" style="max-width: 150px;" />
                            </td>
                        </tr>

                    </table>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-dark" data-bs-dismiss="modal">Close</button>

                </div>

            </div>
        </div>
    </div>


    <div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form id="editForm" method="post" asp-action="Edit" asp-controller="Book" enctype="multipart/form-data">
                    <div class="modal-header">
                        <h5 class="modal-title" id="editModalLabel">Edit Book</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>

                    </div>

                    <div class="modal-body">
                        <input type="hidden" name="Id" id="edit-id" />

                        <div class="form-group">
                            <label>Title</label>
                            <input class="form-control" name="Title" id="edit-title" />
                        </div>

                        <div class="form-group">
                            <label>Author</label>
                            <input class="form-control" name="Author" id="edit-author" />
                        </div>

                        <div class="form-group">
                            <label>ISBN</label>
                            <input class="form-control" name="ISBN" id="edit-isbn" />
                        </div>

                        <div class="form-group">
                            <label>Total Copies</label>
                            <input class="form-control" name="TotalCopies" id="edit-totalcopies" />
                        </div>

                        <div class="form-group">
                            <label>Available Copies</label>
                            <input class="form-control" name="AvailableCopies" id="edit-availablecopies" />
                        </div>

                        <div class="form-group">
                            <label>Category</label>
                            <input class="form-control" name="Category" id="edit-category" />
                        </div>

                        <div class="form-group">
                            <label>Borrowing Days</label>
                            <input class="form-control" name="BorrowingDays" id="edit-borrowingdays" />
                        </div>

                        <div class="form-group">
                            <label>Photo</label>
                            <input type="file" class="form-control-file" name="Photo" />
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>

                        <button type="submit" class="btn btn-success">Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>



</div>



<div class="modal fade" id="borrowBooks" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="exampleModalLabel">Borrow Books</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>

            </div>
            <form asp-action="BorrowedBooks" asp-controller="Book" method="post">
                <div class="modal-body">
                    <div class="form-group">
                        <label for="SelectedStudent">Student  </label>
                        <select asp-for="StudentId" class="form-control select2" id="students">
                            <option value="">Select Student</option>
                            @foreach (var StudentId in Model.Users)
                            {
                                <option value="@StudentId.Id">@StudentId.FullName</option>
                            }
                        </select>

                        <label for="SelectedStudent">Books</label>
                        <select asp-for="BookId" class="form-control select2" id="books">
                            <option value="">Select Book Title</option>
                            @if (Model.Books != null)
                            {
                                foreach (var book in Model.Books)
                                {
                                    <option value="@book.Id">@book.Title</option>
                                }
                            }
                        </select>

                    </div>


                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-dark" data-bs-dismiss="modal">Close</button>

                    <button type="submit" class="btn btn-dark">Submit</button>
                </div>
            </form>
        </div>
    </div>
</div>



<script>
    $(document).ready(function () {
        $('.select2').select2({
            dropdownParent: $('#borrowBooks'),
            width: '100%'
        });
    });
</script>





<script>
    $(document).ready(function () {
        $('.details-button').click(function () {
            var button = $(this);

            $('#detail-title').text(button.data('title'));
            $('#detail-author').text(button.data('author'));
            $('#detail-isbn').text(button.data('isbn'));
            $('#detail-totalcopies').text(button.data('totalcopies'));
            $('#detail-availablecopies').text(button.data('availablecopies'));
            $('#detail-category').text(button.data('category'));
            $('#detail-borrowingdays').text(button.data('borrowingdays'));

            const photoPath = button.data('photopath');
            if (photoPath && photoPath.trim() !== "") {
                $('#detail-photo').attr('src', '/images/' + photoPath);
            } else {
                $('#detail-photo').attr('src', '/images/alt-image.jpg');
            }
        });
    });

</script>
@if (isStudent)
{
    <script>
        new DataTable('#example')
    </script>
}


@if (!isStudent)
{
    <script>
        $(document).ready(function () {
            new DataTable('#example', {
                layout: {
                    topStart: {
                        buttons: [
                            {
                                extend: 'copy',
                                exportOptions: {
                                    columns: [0, 1, 2, 3, 4, 5, 6, 8]
                                }
                            },
                            {
                                extend: 'csv',
                                exportOptions: {
                                    columns: [0, 1, 2, 3, 4, 5, 6, 8]
                                }
                            },
                            {
                                extend: 'excel',
                                exportOptions: {
                                    columns: [0, 1, 2, 3, 4, 5, 6, 8]
                                }
                            },
                            {
                                extend: 'pdf',
                                exportOptions: {
                                    columns: [0, 1, 2, 3, 4, 5, 6, 8]
                                }
                            },
                            {
                                extend: 'print',
                                title: '',
                                customize: function (win) {
                                    const logoUrl = '/images/logo.png';
                                    const institutionName = 'KCA University';
                                    const heading = `
                                                <div style="display: flex; justify-content: space-between;">
                                                    <img src="${logoUrl}" height="50" />
                                                    <div style="text-align: right;">
                                                        <strong>${institutionName}</strong><br/>
                                                        P.O. Box 56808, Nairobi<br/>
                                                        Tel: +254 20 8646103 / 8646108
                                                    </div>
                                                </div>
                                                <hr/>
                                                <p><strong>Books Report</strong></p>
                                            `;
                                    $(win.document.body).prepend(heading);
                                },
                                exportOptions: {
                                    columns: [0, 1, 2, 3, 4, 5, 6, 8]
                                }
                            }
                        ]
                    }
                }
            });
        });


    </script>

}
<script>
    $(document).on('click', '.edit-button', function () {
        const button = $(this);

        $('#edit-id').val(button.data('id'));
        $('#edit-title').val(button.data('title'));
        $('#edit-author').val(button.data('author'));
        $('#edit-isbn').val(button.data('isbn'));
        $('#edit-totalcopies').val(button.data('totalcopies'));
        $('#edit-availablecopies').val(button.data('availablecopies'));
        $('#edit-category').val(button.data('category'));
        $('#edit-borrowingdays').val(button.data('borrowingdays'));

        const formAction = '/Book/Edit/' + button.data('id');
        $('#editForm').attr('action', formAction);
    });

</script>




