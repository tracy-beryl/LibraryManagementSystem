@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}


@model LibraryManagementSystem.ViewModels.BorrowBookViewModel



<div class="container-fluid py-4">
    <h2>Borrowed Books</h2>


    <div class="table-responsive">
        <table id="example" class="table table-bordered table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>No</th>
                    <th>Book Title</th>
                    <th>Student Name</th>
                    <th>Loan Date</th>
                    <th>Return Date</th>
                    <th>Due Date</th>
                    <th>Return</th>
                </tr>
            </thead>
            <tbody>
                @{ 
                    int count = 1;
                }
                @if (Model.Loans.Count > 0)
                {
                    @foreach (var loan in Model.Loans)
                    {
                <tr>
                    <td>@count</td>
                    <td>@loan.Book.Title</td>
                    <td>@loan.User.FullName</td>
                    <td>@loan.LoanDate.ToShortDateString()</td>
                    <td>
                        @if (loan.ReturnDate == null)
                        {
                            <span class="text-danger">Not Returned</span>
                        }
                        else
                        {
                            <span class="text-success">Returned on @loan.ReturnDate.Value.ToShortDateString()</span>
                        }
                    </td>
                    <td>@loan.DueDate.ToShortDateString()</td>
                    <td>
                        @if (loan.ReturnDate == null)
                        {
                            <button type="button"
                                    class="btn btn-dark return-book-btn"
                                    data-loanid="@loan.Id"
                                    data-studentid="@loan.User.Id">
                                Return Book
                            </button>
                        }
                        else
                        {
                            <span class="badge bg-success">Returned</span>
                        }
                    </td>



                </tr>
                        count++;
                    }

                }
        </table>

    </div>

    </div>


<script>

    new DataTable('#example', {
        layout: {
            topStart: {
                buttons: ['copy', 'csv', 'excel', 'pdf', 'print']
            }
        }
    });
</script>

    <script>
    $(document).on('click', '.return-book-btn', function () {
        var loanId = $(this).data('loanid');
        var studentId = $(this).data('studentid');

        Swal.fire({
            title: "Are you sure?",
            text: "You want to return this book?",
            icon: "warning",
            showCancelButton: true,
            confirmButtonText: "Yes, return it!",
            cancelButtonText: "Cancel"
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: '@Url.Action("ReturnedBooks", "Book")',
                    type: 'POST',
                    data: {
                        LoanId: loanId,
                        StudentId: studentId
                    },
                    success: function (response) {
                        Swal.fire("Returned!", "Book has been returned.", "success")
                            .then(() => {
                                location.reload();
                            });
                    },
                    error: function () {
                        Swal.fire("Error!", "Something went wrong.", "error");
                    }
                });
            }
        });
    });
    </script>











