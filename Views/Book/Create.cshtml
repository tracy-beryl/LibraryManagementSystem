
@model LibraryManagementSystem.ViewModels.CreateBookViewModel;



<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm rounded-3">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Add New Book</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post" asp-controller="Book" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label"></label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Author" class="form-label"></label>
                            <input asp-for="Author" class="form-control" />
                            <span asp-validation-for="Author" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="TotalCopies" class="form-label"></label>
                                <input asp-for="TotalCopies" class="form-control" />
                                <span asp-validation-for="TotalCopies" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="AvailableCopies" class="form-label"></label>
                                <input asp-for="AvailableCopies" class="form-control" />
                                <span asp-validation-for="AvailableCopies" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ISBN" class="form-label"></label>
                            <input asp-for="ISBN" class="form-control" />
                            <span asp-validation-for="ISBN" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Category" class="form-label"></label>
                            <input asp-for="Category" class="form-control" />
                            <span asp-validation-for="Category" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Photo" class="form-label"></label>
                            <div class="custom-file">

                                <input asp-for="Photo" type="file" class="form-control custom-file-input" />
                                <label class="custom-file-label">Upload Cover Photo</label>
                            </div>

                        </div>

                        <div class="mb-3">
                            <label asp-for="BorrowingDays" class="form-label"></label>
                            <input asp-for="BorrowingDays" class="form-control" />
                            <span asp-validation-for="BorrowingDays" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">Back</a>
                            <button type="submit" class="btn btn-success">Save Book</button>
                        </div>


                @section Scripts {
                                    <script>
                                        $(document).ready(function () {
                                            $('.custom-file-input').on("change", function () {
                                                var fileName = $(this).val().split("\\").pop();
                                                $(this).next('.custom-file-label').html(fileName);
                                            });
                                        });
                                    </script>
                                }

                    </form>

                    
                </div>
            </div>
        </div>
    </div>
</div>



