@model LibraryManagementSystem.ViewModels.ApproveSuggestionViewModel

@{
    ViewData["Title"] = "Approve Suggestion";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">Approve Book Suggestion</h4>
        </div>

        <div class="card-body">
            <form asp-action="ApproveSuggestion" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="SuggestionId" />

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Title" class="form-label"></label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Author" class="form-label"></label>
                        <input asp-for="Author" class="form-control" />
                        <span asp-validation-for="Author" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="ISBN" class="form-label"></label>
                        <input asp-for="ISBN" class="form-control" />
                        <span asp-validation-for="ISBN" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="ShelfNumber" class="form-label"></label>
                        <input asp-for="ShelfNumber" class="form-control" placeholder="e.g. A-12" />
                        <span asp-validation-for="ShelfNumber" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="BorrowingDays" class="form-label"></label>
                        <input asp-for="BorrowingDays" class="form-control" placeholder="e.g. 5" />
                        <span asp-validation-for="BorrowingDays" class="text-danger"></span>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="TotalCopies" class="form-label"></label>
                        <input asp-for="TotalCopies" class="form-control" type="number" min="1" />
                        <span asp-validation-for="TotalCopies" class="text-danger"></span>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="AvailableCopies" class="form-label"></label>
                        <input asp-for="AvailableCopies" class="form-control" type="number" min="0" />
                        <span asp-validation-for="AvailableCopies" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Category" class="form-label"></label>
                        <input asp-for="Category" class="form-control" placeholder="Optional" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Department" class="form-label"></label>
                        <input asp-for="Department" class="form-control" placeholder="Optional" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Edition" class="form-label"></label>
                        <input asp-for="Edition" class="form-control" placeholder="Optional" />
                    </div>

                    <div class="col-12 mb-3">
                        <div class="form-check">
                            <input asp-for="IsBorrowable" class="form-check-input" />
                            <label asp-for="IsBorrowable" class="form-check-label"></label>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">Approve and Save</button>
                    <a asp-action="BookSuggestions" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}