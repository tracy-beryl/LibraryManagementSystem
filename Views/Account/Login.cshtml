@model LibraryManagementSystem.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="login-page d-flex justify-content-center align-items-center" style="min-height: 100vh;">
    <div class="card login-card shadow-lg w-100">
        <div class="card-body">
            <h2 class="card-title text-center mb-4">Login</h2>

            <form asp-action="Login" method="post">
                <div asp-validation-summary="All" class="alert alert-danger"></div>

                <div class="form-group">
                    <label asp-for="Email" class="font-weight-bold"></label>
                    <input asp-for="Email" class="form-control" placeholder="Enter your email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password" class="font-weight-bold"></label>
                    <input asp-for="Password" class="form-control" placeholder="Enter your password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>


                <div class="form-group form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label"></label>
                </div>

                <button type="submit" class="btn btn-primary btn-block">Login</button>
            </form>

            <div class="text-center mt-3">
                <a asp-action="Register" class="text-decoration-none">Register as a new user</a>
            </div>
        </div>
    </div>
</div>




