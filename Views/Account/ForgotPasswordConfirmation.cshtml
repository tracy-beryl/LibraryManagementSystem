@{
    ViewData["Title"] = "Forgot Password Confirmation";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="d-flex justify-content-center align-items-center px-3" style="min-height: 100vh; background-color: #f8f9fa;">
    <div class="card shadow w-100" style="max-width: 500px;">
        <div class="card-header bg-dark text-white text-center">
            <h4 class="mb-0">Password Reset Requested</h4>
        </div>

        <div class="card-body text-center">
            <p class="mb-3">
                If your email exists in our system, you will receive a password reset link shortly.
            </p>
            <a asp-action="Login" class="btn btn-dark">Back to Login</a>
        </div>
    </div>
</div>

