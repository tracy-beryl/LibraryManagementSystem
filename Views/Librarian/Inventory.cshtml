@model LibraryManagementSystem.ViewModels.InventoryIndexViewModel

@{
    ViewData["Title"] = "Inventory Management";
}

<div class="container-fluid py-4 bg-dark min-vh-100">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-white fw-bold mb-0">Inventory Management</h2>
            <p class="text-muted mb-0">Monitor stock levels, damaged items, and missing copies</p>
        </div>

        <div class="d-flex gap-2">
            <a asp-controller="Librarian" asp-action="AddStock" class="btn btn-outline-primary">
                Add Stock
            </a>
            <a asp-controller="Librarian" asp-action="ReportDamage" class="btn btn-outline-danger">
                Report Damage/Missing
            </a>
            <a asp-controller="Librarian" asp-action="Dashboard" class="btn btn-outline-light">
                Back to Dashboard
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card bg-dark border-secondary shadow-sm mb-4">
        <div class="card-body">
            <form method="get" asp-action="Inventory" class="row g-3">
                <div class="col-md-6">
                    <label class="form-label text-light">Search</label>
                    <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control"
                           placeholder="Search by title, author, or category" />
                </div>

                <div class="col-md-4">
                    <label class="form-label text-light">Status Filter</label>
                    <select name="statusFilter" class="form-select">
                        <option value="">All</option>
                        <option value="LowStock" selected="@(Model.StatusFilter == "LowStock")">Low Stock</option>
                        <option value="Damaged" selected="@(Model.StatusFilter == "Damaged")">Damaged</option>
                        <option value="Missing" selected="@(Model.StatusFilter == "Missing")">Missing</option>
                        <option value="Healthy" selected="@(Model.StatusFilter == "Healthy")">Healthy</option>
                    </select>
                </div>

                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-outline-info w-100">Filter</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card bg-dark border-secondary shadow-sm">
        <div class="card-header border-secondary">
            <h5 class="text-white mb-0">Inventory Records</h5>
        </div>

        <div class="card-body">
            @if (Model.Items.Any())
            {
                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Author</th>
                                <th>Category</th>
                                <th>Total</th>
                                <th>Available</th>
                                <th>Damaged</th>
                                <th>Missing</th>
                                <th>Threshold</th>
                                <th>Status</th>
                                <th>Last Updated</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>@item.BookTitle</td>
                                    <td>@item.Author</td>
                                    <td>@item.Category</td>
                                    <td>@item.TotalCopies</td>
                                    <td>@item.AvailableCopies</td>
                                    <td>@item.DamagedCopies</td>
                                    <td>@item.MissingCopies</td>
                                    <td>@item.ReorderThreshold</td>
                                    <td>
                                        @if (item.HasMissing)
                                        {
                                            <span class="badge bg-warning text-dark">Missing</span>
                                        }
                                        else if (item.HasDamage)
                                        {
                                            <span class="badge bg-danger">Damaged</span>
                                        }
                                        else if (item.IsLowStock)
                                        {
                                            <span class="badge bg-warning text-dark">Low Stock</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Healthy</span>
                                        }
                                    </td>
                                    <td>@item.LastUpdatedAt.ToString("dd MMM yyyy")</td>
                                    <td>
                                        <div class="d-flex flex-wrap gap-1">
                                            <a asp-controller="Librarian"
                                               asp-action="AddStock"
                                               asp-route-bookId="@item.BookId"
                                               class="btn btn-sm btn-outline-primary">
                                                Add
                                            </a>
                                            <a asp-controller="Librarian"
                                               asp-action="EditInventory"
                                               asp-route-id="@item.InventoryRecordId"
                                               class="btn btn-sm btn-outline-warning">
                                                Edit
                                            </a>
                                            <a asp-controller="Librarian"
                                               asp-action="ReportDamage"
                                               asp-route-bookId="@item.BookId"
                                               class="btn btn-sm btn-outline-danger">
                                                Report
                                            </a>

                                            <a asp-controller="Librarian"
                                               asp-action="InventoryHistory"
                                               asp-route-bookId="@item.BookId"
                                               class="btn btn-sm btn-outline-info">
                                                History
                                            </a>
                                            <a asp-controller="Librarian"
                                               asp-action="ExportInventoryExcel"
                                               asp-route-searchTerm="@Model.SearchTerm"
                                               asp-route-statusFilter="@Model.StatusFilter"
                                               class="btn btn-outline-success">
                                                Export Excel
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">No inventory records found.</div>
            }
        </div>
    </div>
</div>