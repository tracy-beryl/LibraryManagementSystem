@model LibraryManagementSystem.ViewModels.ReportDamageViewModel
@using LibraryManagementSystem.Models

@{
    ViewData["Title"] = "Report Inventory Issue";
    var books = ViewBag.Books as List<Book>;
}

<div class="container py-4">
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">Report Damaged or Missing Book</h4>
        </div>
        <div class="card-body">
            <form asp-action="ReportDamage" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="BookId" class="form-label">Book</label>
                    <select asp-for="BookId" class="form-select">
                        <option value="">Select Book</option>
                        @foreach (var book in books)
                        {
                            <option value="@book.Id">@book.Title</option>
                        }
                    </select>
                    <span asp-validation-for="BookId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ReportType" class="form-label">Issue Type</label>
                    <select asp-for="ReportType" class="form-select">
                        <option value="">Select Type</option>
                        <option value="Damaged">Damaged</option>
                        <option value="Missing">Missing</option>
                    </select>
                    <span asp-validation-for="ReportType" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="QuantityAffected" class="form-label"></label>
                    <input asp-for="QuantityAffected" class="form-control" />
                    <span asp-validation-for="QuantityAffected" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-dark">Submit Report</button>
                <a asp-action="Dashboard" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>