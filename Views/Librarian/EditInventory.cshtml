@model LibraryManagementSystem.ViewModels.EditInventoryViewModel

@{
    ViewData["Title"] = "Edit Inventory";
}

<div class="container py-4">
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">Edit Inventory Record</h4>
        </div>

        <div class="card-body">
            <form asp-action="EditInventory" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input asp-for="InventoryRecordId" type="hidden" />
                <input asp-for="BookId" type="hidden" />

                <div class="mb-3">
                    <label class="form-label fw-bold">Book</label>
                    <input class="form-control" value="@Model.BookTitle" readonly />
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Total Copies</label>
                        <input class="form-control" value="@Model.TotalCopies" readonly />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold">Available Copies</label>
                        <input class="form-control" value="@Model.AvailableCopies" readonly />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold">Damaged Copies</label>
                        <input class="form-control" value="@Model.DamagedCopies" readonly />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold">Missing Copies</label>
                        <input class="form-control" value="@Model.MissingCopies" readonly />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="ReorderThreshold" class="form-label"></label>
                    <input asp-for="ReorderThreshold" class="form-control" />
                    <span asp-validation-for="ReorderThreshold" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Notes" class="form-label"></label>
                    <textarea asp-for="Notes" class="form-control" rows="4"
                              placeholder="Optional reason for changing this threshold"></textarea>
                    <span asp-validation-for="Notes" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-dark">Save Changes</button>
                    <a asp-action="Inventory" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}