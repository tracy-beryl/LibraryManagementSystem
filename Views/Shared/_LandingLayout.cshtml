
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LibraryManagementSystem</title>

   

    <link rel="stylesheet" href="~/css/site.css" />
    @RenderSection("Styles", required: false)
</head>

<body class="bg-light">
    <div class="container py-4">
        @RenderBody()
    </div>

    <!-- FOOTER -->
    <footer class="bg-dark text-light pt-5 pb-4">
        <div class="container">
            <div class="row text-center text-md-start">
                <!-- Contact Info -->
                <div class="col-md-4 mb-4">
                    <h5 class="fw-bold text-warning">📞 Contact Us</h5>
                    <p><strong>Address:</strong> Ojijo Street, Westlands, Nairobi</p>
                    <p><strong>Phone:</strong> +254 712 345 678</p>
                    <p><strong>Email:</strong> <a href="mailto:betalibrary@ac.ke" class="text-warning text-decoration-none">betalibrary@ac.ke</a></p>
                </div>

                <!-- Quick Links -->
                <div class="col-md-2 mb-4">
                    <h5 class="fw-bold text-warning">Quick Links</h5>
                    <ul class="list-unstyled">
                        <li><span><a asp-controller="Home" asp-action="Index" class="text-light text-decoration-none">Home</a></span></li>
                        <li><span><a asp-controller="Home" asp-action="About" class="text-light text-decoration-none">About</a></span></li>
                        <li><span><a asp-controller="Book" asp-action="Index" class="text-light text-decoration-none">Books</a></span></li>
                        <li><span><a asp-controller="Account" asp-action="Login" class="text-light text-decoration-none">Login</a></span></li>
                    </ul>
                </div>

                <!-- Services -->
                <div class="col-md-3 mb-4">
                    <h5 class="fw-bold text-warning">Library Services</h5>
                    <ul class="list-unstyled">
                        <li><span>📔 Book Borrowing</span></li>
                        <li><span>📄 Access to Past Papers</span></li>
                        <li><span>🧑‍💻 Study & IT Support</span></li>
                        <li><span>✍️ Reading & Research</span></li>
                    </ul>
                </div>

                <!-- Newsletter (Placeholder) -->
                <div class="col-md-3 mb-4">
                    <h5 class="fw-bold text-warning">Stay Updated</h5>
                    <p>Subscribe to our newsletter for updates and resources.</p>
                    <form>
                        <div class="input-group">
                            <input type="email" class="form-control" placeholder="Your email" disabled>
                            <button class="btn btn-warning" type="button" disabled>Subscribe</button>
                        </div>
                        <small class="text-muted">Coming Soon</small>
                    </form>
                </div>
            </div>

            <hr class="border-top border-light my-3" />

            <!-- Copyright -->
            <div class="row">
                <div class="col-12 text-center">
                    <p class="mb-0 small">
                        © @DateTime.Now.Year Beta Library. All Rights Reserved. |
                        <a href="#" class="text-warning text-decoration-none">Privacy Policy</a> |
                        <a href="#" class="text-warning text-decoration-none">Terms of Use</a>
                    </p>
                </div>
            </div>
        </div>
    </footer>





    @RenderSection("Scripts", required: false)
</body>
</html>
