@using Microsoft.AspNetCore.Identity
@using LibraryManagementSystem.Models;
@inject SignInManager<LibraryManagementSystem.Models.ApplicationUser> signInManager;
@inject UserManager<LibraryManagementSystem.Models.ApplicationUser> user;

@inject LibraryManagementSystem.Service.MyService service;
@{
    var loggedIdUser = await user.GetUserAsync(User);
    var isStudent = false;
    if (loggedIdUser != null)
    {
        isStudent = await service.IsStudent(loggedIdUser.Id);

        var name = loggedIdUser.Email;
    }
}



