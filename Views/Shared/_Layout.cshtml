    <script src="~/js/sw-register.js"></script>
    <script>
        window.addEventListener('load', function () {
            if (window.pwaSync && typeof window.pwaSync.init === 'function') {
                window.pwaSync.init();
            }
        });
    </script>

    <script>
        function loadInviteCount() {
            fetch('/StudyHub/GetPendingInvitationCount')
                .then(response => {
                    if (!response.ok) {
                        throw new Error("Server returned " + response.status);
                    }
                    return response.json();
                })
                .then(data => {
                    const badge = document.getElementById('inviteBadge');
                    badge.innerText = data.count;
                    badge.style.display = data.count > 0 ? 'inline-block' : 'none';
                })
                .catch(err => console.error(err));
        }

        loadInviteCount();
        setInterval(loadInviteCount, 30000); // refresh every 30 seconds
    </script>

