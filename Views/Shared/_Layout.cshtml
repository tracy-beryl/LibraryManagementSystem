@using Microsoft.AspNetCore.Identity
@using LibraryManagementSystem.Models;
@inject SignInManager<LibraryManagementSystem.Models.ApplicationUser> signInManager;
@inject UserManager<LibraryManagementSystem.Models.ApplicationUser> user;
@inject LibraryManagementSystem.Service.MyService service;
@{
    var loggedIdUser = await user.GetUserAsync(User);
    var isStudent = false;
    if (loggedIdUser != null)
    {
        isStudent = await service.IsStudent(loggedIdUser.Id);

        var name = loggedIdUser.Email;
    }
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LibraryManagementSystem</title>
    <environment include="Development">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.3.3/css/bootstrap.min.css" />
        <link rel="stylesheet" href="https://cdn.datatables.net/2.3.2/css/dataTables.bootstrap5.css" />

        <script src="sweetalert2.min.js"></script>
        <link rel="stylesheet" href="sweetalert2.min.css">
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script src="https://code.jquery.com/jquery-3.7.1.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.3.3/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.datatables.net/2.3.2/js/dataTables.js"></script>
        <script src="https://cdn.datatables.net/2.3.2/js/dataTables.bootstrap5.js"></script>

        <link href="~/lib/bootstrap/css/bootstrap.css" rel="stylesheet" />
        <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
        <script src="~/lib/jquery/dist/jquery.js"></script>
        <script src="~/lib/jquery-validate/jquery.validate.js"></script>
        <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.js"></script>
    </environment>

    <environment exclude="Development">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" rel="stylesheet"
              integrity="sha384-4Q6Gf2aSP4eDXB8Miphtr37CMZZQ5oXLH2yaXMJ2w8e2ZtHTl7GptT4jmndRuHDT"
              crossorigin="anonymous"
              asp-fallback-href="~/lib/bootstrap/css/bootstrap.min.css"
              asp-fallback-test-class="sr-only" asp-fallback-test-property="position"
              asp-fallback-test-value="absolute"
              asp-suppress-fallback-integrity="true" />
    </environment>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <header class="fixed-top">
        <nav class="navbar navbar-expand-lg navbar-light bg-white">
            <div class="container-fluid">
                @if (signInManager.IsSignedIn(User))
                {

                    <ul class="navbar-nav d-flex flex-row gap-3 align-items-center">
                        <li class="nav-item">
                            <div>
                                <a class="navbar-brand" asp-controller="home" asp-action="index">
                                    <img src="~/images/house.svg" width="20" height="20">
                                    <span class="navbar-text">Home</span>
                                </a>
                            </div>
                            
                        </li>
                        <li class="nav-item"  asp-controller="home" asp-action="about">About Library</li>
                        <li class="nav-item">Services</li>
                        <li class="nav-item">
                            <div>
                                <a class="navbar-brand" asp-controller="book" asp-action="index">
                                    <img src="~/images/book.svg" width="20" height="20">
                                  
                                    <span class="navbar-text">Books</span>
                                </a>
                            </div>
                        </li>
                        <li class="nav-item">New Books</li>
                    </ul>

                    <div>
                        <a asp-action="Logout" asp-controller="Account" class="btn btn-primary">Logout</a>
                    </div>
                }
            </div>
        </nav>
    </header>

    <div class="row container-fluid mt-5">
        <div class="col-2">
            @if (signInManager.IsSignedIn(User))
            {


                <div class="sidenav">
                    <nav class="sidenav1 bg-white">
                        @if (!isStudent)
                        {
                            <ul class="sidebar-menu">
                                <li style="list-style:none; ">
                                    <div>
                                        <a class="navbar-brand" asp-controller="account" asp-action="dashboard">
                                            <img src="~/images/home.png" width="20" height="20">
                                            <span class="navbar-text">Dashboard</span>
                                        </a>
                                    </div>
                                </li>

                            </ul>
                         }

                        <ul class="sidebar-menu">
                            <li style="list-style:none">
                                <div>
                                    <a class="navbar-brand" asp-controller="book" asp-action="index">
                                        <img src="~/images/book.svg" width="20" height="20">

                                        <span class="navbar-text">Books</span>
                                    </a>
                                </div>
                            </li>
                        </ul>
                          @if (!isStudent)
                           {

                                <ul class="sidebar-menu">
                                    <li style="list-style:none; ">
                                        <a asp-action="BorrowedBooks" asp-controller="book">Borrowed Books</a>
                                    </li>
                                </ul>
                           }

                        @if (isStudent)
                        {
                            <ul class="sidebar-menu">
                                <li style="list-style:none; ">
                                    <div>
                                        <a class="navbar-brand" asp-controller="StudentDashboard" asp-action="index">
                                            <img src="~/images/home.png" width="20" height="20">

                                            <span class="navbar-text">StudentDashboard</span>
                                        </a>
                                    </div>
                                    
                                </li>
                            </ul>
                            <ul class="sidebar-menu">
                                <li style="list-style:none; ">
                                    <a asp-action="MyBorrowedBooks" asp-controller="book">My Borrowed Books</a>
                                </li>
                            </ul>

                            <ul class="sidebar-menu">
                                <li style="list-style:none; ">
                                    <a asp-action="MyHistory" asp-controller="book">My History</a>
                                </li>
                            </ul>
                        }

                        @if (!isStudent)
                        {
                            <ul class="sidebar-menu">
                                <li style="list-style:none; ">
                                    <a asp-action="ReturnedBooks" asp-controller="book">ReturnedHistory</a>
                                </li>
                            </ul>

                        }

                        <ul class="sidebar-menu">
                            <li style="list-style:none; ">
                                <a asp-action="PastPapers" asp-controller="PastPapers">PastPapers</a>
                            </li>
                        </ul>
                        @if (!isStudent)
                        {
                            <ul class="sidebar-menu">
                                <li style="list-style:none; ">
                                    <a asp-action="Index" asp-controller="UserManagement">User Management</a>
                                </li>
                            </ul>
                         }
                    </nav>
                </div>


            }

        </div>

    </div>

    <div>
        @RenderBody()
    </div>


    @RenderSection("Scripts", required: false)



</body>
</html>
