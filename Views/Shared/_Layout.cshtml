@using Microsoft.AspNetCore.Identity
@using LibraryManagementSystem.Models;
@inject SignInManager<ApplicationUser> signInManager;
@inject UserManager<ApplicationUser> user;
@inject LibraryManagementSystem.Service.MyService service;

@{
    var loggedIdUser = await user.GetUserAsync(User);
    var isStudent = false;
    if (loggedIdUser != null)
    {
        isStudent = await service.IsStudent(loggedIdUser.Id);
    }
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title></title>

    <environment include="Development">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.3.3/css/bootstrap.min.css" />
        <link rel="stylesheet" href="https://cdn.datatables.net/2.3.2/css/dataTables.bootstrap5.css" />

        <script src="https://code.jquery.com/jquery-3.7.1.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.3.3/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.datatables.net/2.3.2/js/dataTables.js"></script>
        <script src="https://cdn.datatables.net/2.3.2/js/dataTables.bootstrap5.js"></script>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

        @*exporting data*@
        <link rel="stylesheet" href="https://cdn.datatables.net/2.3.2/css/dataTables.dataTables.css" />
        <link rel="stylesheet" href="https://cdn.datatables.net/buttons/3.2.4/css/buttons.dataTables.css" />
        <script src="https://code.jquery.com/jquery-3.7.1.js"></script>
        <script src="https://cdn.datatables.net/2.3.2/js/dataTables.js"></script>
        <script src="https://cdn.datatables.net/buttons/3.2.4/js/dataTables.buttons.js"></script>
        <script src="https://cdn.datatables.net/buttons/3.2.4/js/buttons.dataTables.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
        <script src="https://cdn.datatables.net/buttons/3.2.4/js/buttons.html5.min.js"></script>
        <script src="https://cdn.datatables.net/buttons/3.2.4/js/buttons.print.min.js"></script>

        <!-- Select2 CSS -->
        <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

        <!-- jQuery (required by Select2) -->
        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

        <!-- Select2 JS -->
        <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>


        <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
        <script src="~/lib/jquery-validate/jquery.validate.js"></script>
        <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.js"></script>
    </environment>


    <environment exclude="Development">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" rel="stylesheet"
              integrity="sha384-4Q6Gf2aSP4eDXB8Miphtr37CMZZQ5oXLH2yaXMJ2w8e2ZtHTl7GptT4jmndRuHDT"
              crossorigin="anonymous"
              asp-fallback-href="~/lib/bootstrap/css/bootstrap.min.css"
              asp-fallback-test-class="sr-only" asp-fallback-test-property="position"
              asp-fallback-test-value="absolute"
              asp-suppress-fallback-integrity="true" />
    </environment>


   
    @RenderSection("Styles", required: false)



    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding-top: 83px;
        }

        header nav.custom_navbar {
            background-color: #212529;
        }

        .navbar-dark .nav-link {
            color: #f8f9fa !important;
        }

            .navbar-dark .nav-link:hover {
                color: #ffc107 !important;
            }




        .sidenav1 {
            position: fixed;
            top: 83px;
            left: 0;
            width: 220px;
            height: calc(100vh - 83px);
            background-color: #212529;
            color: #f8f9fa;
            padding-top: 1rem;
            max-height: 100vh;
            overflow-y: auto;
        }

        .sidebar-menu .navbar-brand {
            display: flex;
            align-items: center;
            gap: 2px;
            margin-bottom: 0.5rem;
        }

        .sidebar-item {
            list-style: none;
        }


        .sidenav1 .navbar-brand {
            color: #f8f9fa !important;
            display: flex;
            align-items: center;
            gap: 2px;
            font-weight: 500;
            padding: 0.1rem 0;
            text-decoration: none;
        }

            .sidenav1 .navbar-brand:hover {
                color: #ffc107 !important;
            }

        .sidenav a:hover {
            background-color: #f8f9fa;
            color: #f8f9fa;
        }
    </style>
</head>

<body>
    <header class="fixed-top">
        <!-- FIXED NAVBAR -->
        <nav class="custom_navbar navbar navbar-expand-lg navbar-dark fixed-top shadow">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="home" asp-action="index">📚 Beta Library</a>

                <!-- Navbar toggler for small screens -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Collapsible content -->
                <div class="collapse navbar-collapse" id="navbarMenu">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ">
                        <li class="nav-item"><a class="nav-link" asp-controller="home" asp-action="about">About</a></li>
                        <li class="nav-item"><a class="nav-link" href="#">New Books</a></li>
                        <li class="nav-item"><a class="nav-link" href="#">Services</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="book" asp-action="index">Books</a></li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item"><a class="nav-link" asp-controller="account" asp-action="logout">Logout</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>


    <div class="container-fluid">
        <div class="row">
            @if (signInManager.IsSignedIn(User))
            {
                <!-- Toggle Button for Small Screens -->
                <div class="col-12 d-md-none my-2">
                    <button class="btn btn-outline-dark w-100" type="button" data-bs-toggle="collapse" data-bs-target="#sidebarCollapse">
                        ☰ Toggle Menu
                    </button>
                </div>

                <!-- Sidebar -->
                <div class="col-md-3 col-lg-2 collapse d-md-block p-0" id="sidebarCollapse">
                    <div class="sticky-sidebar">
                        <nav class="sidenav1 px-3">
                            @if (!isStudent)
                            {
                                <ul class="sidebar-menu">
                                    <li class="sidebar-item">
                                        <a class="navbar-brand" asp-controller="account" asp-action="dashboard">
                                            <img src="~/images/statistics.png" class="img-fluid" style="max-width: 20px;" />
                                            <span class="navbar-text">Dashboard</span>
                                        </a>
                                    </li>
                                </ul>
                            }

                            <ul class="sidebar-menu">
                                <li class="sidebar-item">
                                    <a class="navbar-brand" asp-controller="book" asp-action="index">
                                        <img src="~/images/open-book.png" class="img-fluid" style="max-width: 20px;" />
                                        <span class="navbar-text">Books</span>
                                    </a>
                                </li>
                            </ul>

                            @if (!isStudent)
                            {
                                <ul class="sidebar-menu">
                                    <li class="sidebar-item">
                                        <a class="navbar-brand" asp-controller="book" asp-action="borrowedbooks">
                                            <img src="~/images/stack-of-books.png" class="img-fluid" style="max-width: 20px;" />
                                            <span class="navbar-text">Borrowed Books</span>
                                        </a>
                                    </li>
                                    <li class="sidebar-item">
                                        <a class="navbar-brand" asp-controller="book" asp-action="returnedBooks">
                                            <img src="~/images/history.png" class="img-fluid" style="max-width: 20px;" />
                                            <span class="navbar-text">Returned History</span>
                                        </a>
                                    </li>
                                </ul>
                            }

                            @if (isStudent)
                            {
                                <ul class="sidebar-menu">
                                    <li class="sidebar-item">
                                        <a class="navbar-brand" asp-controller="StudentDashboard" asp-action="index">
                                            <img src="~/images/statistics.png" class="img-fluid" style="max-width: 20px;" />
                                            <span class="navbar-text">Student Dashboard</span>
                                        </a>
                                    </li>
                                    <li class="sidebar-item">
                                        <a class="navbar-brand" asp-controller="book" asp-action="myborrowedbooks">
                                            <img src="~/images/stack-of-books.png" class="img-fluid" style="max-width: 20px;" />
                                            <span class="navbar-text">My Borrowed Books</span>
                                        </a>
                                    </li>
                                    <li class="sidebar-item">
                                        <a class="navbar-brand" asp-controller="book" asp-action="myhistory">
                                            <img src="~/images/history.png" class="img-fluid" style="max-width: 20px;" />
                                            <span class="navbar-text">My History</span>
                                        </a>
                                    </li>
                                    <li class="sidebar-item">
                                        <a class="navbar-brand" asp-controller="fine" asp-action="myfines">
                                            <img src="~/images/fine.png" class="img-fluid" style="max-width: 20px;" />
                                            <span class="navbar-text">My Fines</span>
                                        </a>
                                    </li>
                                </ul>
                            }

                            <ul class="sidebar-menu">
                                <li class="sidebar-item">
                                    <a class="navbar-brand" asp-controller="pastpapers" asp-action="pastpapers">
                                        <img src="~/images/document.png" class="img-fluid" style="max-width: 20px;" />
                                        <span class="navbar-text">Past Papers</span>
                                    </a>
                                </li>
                            </ul>

                            <ul class="sidebar-menu">
                                <li class="sidebar-item">
                                    <a class="navbar-brand" asp-controller="softcopy" asp-action="index">
                                        <img src="~/images/document.png" class="img-fluid" style="max-width: 20px;" />
                                        <span class="navbar-text">Soft Copies</span>
                                    </a>
                                </li>
                            </ul>

                            @if (!isStudent)
                            {
                                <ul class="sidebar-menu">
                                    <li class="sidebar-item">
                                        <a class="navbar-brand" asp-controller="usermanagement" asp-action="index">
                                            <img src="~/images/group.png" class="img-fluid" style="max-width: 20px;" />
                                            <span class="navbar-text">User Management</span>
                                        </a>
                                    </li>
                                    <li class="sidebar-item">
                                        <a class="navbar-brand" asp-controller="fine" asp-action="index">
                                            <img src="~/images/fine.png" class="img-fluid" style="max-width: 20px;" />
                                            <span class="navbar-text">Fine</span>
                                        </a>
                                    </li>
                                    <li class="sidebar-item">
                                        <a class="navbar-brand" asp-controller="report" asp-action="index">
                                            <img src="~/images/myreport.png" class="img-fluid" style="max-width: 20px;" />
                                            <span class="navbar-text">Reports</span>
                                        </a>
                                    </li>
                                    <li class="sidebar-item">
                                        <a class="navbar-brand" asp-controller="Settings" asp-action="index">
                                            <img src="~/images/myreport.png" class="img-fluid" style="max-width: 20px;" />
                                            <span class="navbar-text">Settings</span>
                                        </a>
                                    </li>
                                </ul>
                            }
                        </nav>
                    </div>
                </div>
            }

            <!-- Main Content Area -->
            <div class="col-12 col-md-9 col-lg-10">
                @RenderBody()
            </div>
        </div>
    </div>


    @RenderSection("Scripts", required: false)


</body>
</html>
