@using Microsoft.AspNetCore.Identity
@using LibraryManagementSystem.Models;
@inject SignInManager<LibraryManagementSystem.Models.ApplicationUser> signInManager;
@inject UserManager<LibraryManagementSystem.Models.ApplicationUser> user;

@{
    var loggedIdUser = await user.GetUserAsync(User);
    if(loggedIdUser != null)
    {
        var name = loggedIdUser.Email;
    }
}

<!DOCTYPE html>
<html lang="en">
<style>
    .sidenav {
        height: 100%;
        width: 250px;
        position: fixed;
        top: 83px;
        left: 0;
        background-color: white;
        padding-top: 20px;
        z-index: 1;
    }

        .sidenav a {
            padding: 10px 20px;
            text-decoration: none;
            font-size: 18px;
            color: #333;
            display: block;
            transition: 0.3s;
        }

            .sidenav a:hover {
                background-color: #ddd;
                color: #000;
            }

    .main {
        margin-left: 250px;
        margin-top: 100px;
    }


    .dashboard-content {
        margin-left: 250px;
        padding-top: 100px;
    }
</style>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LibraryManagementSystem</title>
    <environment include="Development">
        <link href="~/lib/bootstrap/css/bootstrap.css" rel="stylesheet" />

        <script src="~/lib/jquery/dist/jquery.js"></script>
        <script src="~/lib/jquery-validate/jquery.validate.js"></script>
        <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.js"></script>
    </environment>

    <environment exclude="Development">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" rel="stylesheet"
              integrity="sha384-4Q6Gf2aSP4eDXB8Miphtr37CMZZQ5oXLH2yaXMJ2w8e2ZtHTl7GptT4jmndRuHDT"
              crossorigin="anonymous"
              asp-fallback-href="~/lib/bootstrap/css/bootstrap.min.css"
              asp-fallback-test-class="sr-only" asp-fallback-test-property="position"
              asp-fallback-test-value="absolute"
              asp-suppress-fallback-integrity="true" />
    </environment>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <header class="fixed-top">
        <nav class="navbar navbar-expand-lg navbar-light bg-white">
            <div class="container-fluid">
                @if (signInManager.IsSignedIn(User))
                {
                    
                    <ul class="navbar-nav d-flex flex-row gap-3 align-items-center">
                        <li class="nav-item">Home</li>
                        <li class="nav-item">About Library</li>
                        <li class="nav-item">Services</li>
                        <li class="nav-item">Books</li>
                        <li class="nav-item">New Books</li>
                    </ul>

                    <div>
                        <a asp-action="Logout" asp-controller="Account" class="btn btn-primary">Logout</a>
                    </div>
                }
            </div>
        </nav>
      </header>

        <div class="row container-fluid mt-5">
            <div class="col-2">
                @if (signInManager.IsSignedIn(User))
                {
                    <div class="sidenav">
                        <nav class="sidenav1 bg-white">
                            <ul class="sidebar-menu">
                                <li style="list-style:none; ">
                                    <a asp-action="dashboard" asp-controller="account">Dashboard</a>
                                </li>

                            </ul>
                            <ul class="sidebar-menu">
                                <li style="list-style:none">
                                    <a asp-action="Index" asp-controller="book">Books</a>
                                </li>
                            </ul>
                            <ul class="sidebar-menu">
                                <li style="list-style:none; ">
                                    <a asp-action="BorrowedBooks" asp-controller="book">Borrowed Books</a>
                                </li>
                            </ul>
                            <ul class="sidebar-menu">
                                <li style="list-style:none; ">
                                    <a asp-action="ReturnedBooks" asp-controller="book">ReturnedHistory</a>
                                </li>
                            </ul>
                            <ul class="sidebar-menu">
                                <li style="list-style:none; ">
                                    <a asp-action="PastPapers" asp-controller="PastPapers">PastPapers</a>
                                </li>
                            </ul>

                            <ul class="sidebar-menu">
                                <li style="list-style:none; ">
                                    <a asp-action="Index" asp-controller="UserManagement">User Management</a>
                                </li>
                            </ul>
                        </nav>
                    </div>


                }

            </div>

        </div>

        <div>
            @RenderBody()
        </div>


        @RenderSection("Scripts", required: false)



</body>
</html>
