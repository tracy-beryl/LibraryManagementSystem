@model IEnumerable<LibraryManagementSystem.Models.CDACC.LibraryResource>

@{
    ViewData["Title"] = "Library Resources";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Library Resources</h2>
            <p class="text-muted mb-0">Manage uploaded resources and competency mappings.</p>
        </div>

        <a asp-action="CreateResource" class="btn btn-primary">
            Create Resource
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="alert alert-info mb-0">
                    No resources have been added yet.
                </div>
            }
            else
            {
        <div class="table-responsive">
            <table id="example" class="table table-bordered table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Type</th>
                        <th>Reference No.</th>
                        <th>Mapped Standards</th>
                        <th>Status</th>
                        <th style="width: 280px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@r.Title</td>
                            <td>@r.Type</td>
                            <td>@r.ReferenceNumber</td>
                            <td>@r.ResourceCompetencies.Count(rc => rc.IsActive)</td>
                            <td>
                                @if (r.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex flex-wrap gap-2">
                                    <a asp-action="MapResource"
                                       asp-route-resourceId="@r.Id"
                                       class="btn btn-sm btn-outline-info">
                                        Map
                                    </a>

                                    <a asp-action="EditResource"
                                       asp-route-id="@r.Id"
                                       class="btn btn-sm btn-outline-warning">
                                        Edit
                                    </a>

                                    <a asp-action="DeleteResource"
                                       asp-route-id="@r.Id"
                                       class="btn btn-sm btn-outline-danger">
                                        Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
            }
        </div>
    </div>
</div>

@section Scripts{
    <script>
        new DataTable('#example')
    </script>
}