@model LibraryManagementSystem.Models.CDACC.LibraryResource
@{
    ViewData["Title"] = "Delete Resource";
}

<h2>Delete Resource</h2>

<div class="alert alert-warning">
    Are you sure you want to delete this resource?
</div>

<div class="mb-3">
    <strong>Title:</strong> @Model.Title
</div>

<div class="mb-3">
    <strong>Type:</strong> @Model.Type
</div>

<div class="mb-3">
    <strong>Reference:</strong> @Model.ReferenceNumber
</div>

<form asp-action="DeleteResource" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Resources" class="btn btn-secondary">Cancel</a>
</form>