@model LibraryManagementSystem.ViewModels.StudentDashboardViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4 bg-dark min-vh-100">
    <div class="mb-4">
        <h3 class="text-white fw-bold">Hello, @Model.FirstName</h3>
        <p class="text-light mb-0">
            Today is @DateTime.Now.ToString("dddd, MMMM dd, yyyy - hh:mm tt")
        </p>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-12 col-sm-6 col-lg-2">
            <div class="card shadow border-0 h-100 text-white" style="background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);">
                <div class="card-body text-center">
                    <i class="bi bi-book-fill fs-1"></i>
                    <h6 class="mt-2">Borrowed</h6>
                    <p class="display-6 fw-bold">@Model.MyBorrowedBooks</p>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-2">
            <div class="card shadow border-0 h-100 text-white" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);">
                <div class="card-body text-center">
                    <i class="bi bi-clock-history fs-1"></i>
                    <h6 class="mt-2">History</h6>
                    <p class="display-6 fw-bold">@Model.MyHistory</p>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-2">
            <div class="card shadow border-0 h-100 text-white" style="background: linear-gradient(135deg, #f7971e 0%, #ffd200 100%);">
                <div class="card-body text-center">
                    <i class="bi bi-calendar-event fs-1"></i>
                    <h6 class="mt-2">Due Soon</h6>
                    <p class="display-6 fw-bold">@Model.DueSoonCount</p>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-2">
            <div class="card shadow border-0 h-100 text-white" style="background: linear-gradient(135deg, #cb2d3e 0%, #ef473a 100%);">
                <div class="card-body text-center">
                    <i class="bi bi-exclamation-triangle-fill fs-1"></i>
                    <h6 class="mt-2">Overdue</h6>
                    <p class="display-6 fw-bold">@Model.OverdueCount</p>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-2">
            <div class="card shadow border-0 h-100 text-white" style="background: linear-gradient(135deg, #1d976c 0%, #93f9b9 100%);">
                <div class="card-body text-center">
                    <i class="bi bi-people-fill fs-1"></i>
                    <h6 class="mt-2">Projects</h6>
                    <p class="display-6 fw-bold">@Model.MyActiveProjects</p>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-2">
            <div class="card shadow border-0 h-100 text-white" style="background: linear-gradient(135deg, #4568dc 0%, #b06ab3 100%);">
                <div class="card-body text-center">
                    <i class="bi bi-envelope-fill fs-1"></i>
                    <h6 class="mt-2">Invitations</h6>
                    <p class="display-6 fw-bold">@Model.PendingInvitations</p>
                </div>
            </div>
        </div>
    </div>
    <div class="row g-4 mt-1">
        <div class="col-lg-6">
            <div class="card bg-dark border-secondary shadow-sm mb-4 h-100">
                <div class="card-header border-secondary
                    d-flex justify-content-between align-items-center">
                    <h5 class="text-white mb-0">Learning Progress</h5>
                    <a asp-controller="LearningPath" asp-action="Index" class="btn btn-sm btn-light">Open Learning Path</a>
                </div>
                <div class="card-body text-white d-flex flex-column">
                    <h4 class="fw-bold">@Model.LearningResourcesCompleted / @Model.LearningResourcesTotal</h4>
                    <p class="text-muted">Resources completed</p>

                    <div class="progress" style="height: 22px;">
                        <div class="progress-bar bg-info"
                             role="progressbar"
                             style="width: @Model.LearningCompletionPercent%;"
                             aria-valuenow="@Model.LearningCompletionPercent"
                             aria-valuemin="0"
                             aria-valuemax="100">
                            @Model.LearningCompletionPercent%
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card bg-dark border-secondary shadow-sm mb-4 h-100">
                <div class="card-header border-secondary
                    d-flex justify-content-between align-items-center">
                    <h5 class="text-white mb-0">Continue Learning</h5>
                </div>
                <div class="card-body text-white d-flex flex-column">
                    @if (Model.ContinueLearning.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var item in Model.ContinueLearning)
                            {
                                <li class="list-group-item">
                                    <div class="fw-semibold">@item.Title</div>
                                    <div class="small text-muted">@item.UnitCode - @item.UnitName</div>
                                    <div class="small text-primary">@item.ResourceType</div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No pending learning resources right now.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-1">
        <div class="col-12">
            <div class="card bg-dark border-secondary shadow-sm mb-4">
                <div class="card-header border-secondary">
                    <h5 class="text-white mb-0">Units In Progress</h5>
                </div>
                <div class="card-body bg-dark">
                    @if (Model.UnitProgress.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered align-middle text-white">
                                <thead>
                                    <tr>
                                        <th>Unit Code</th>
                                        <th>Unit Name</th>
                                        <th>Completed</th>
                                        <th>Total</th>
                                        <th>Progress</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var unit in Model.UnitProgress)
                                    {
                                        var percent = unit.TotalResources == 0
                                            ? 0
                                            : Math.Round((double)unit.CompletedResources / unit.TotalResources * 100, 1);

                                        <tr>
                                            <td>@unit.UnitCode</td>
                                            <td>@unit.UnitName</td>
                                            <td>@unit.CompletedResources</td>
                                            <td>@unit.TotalResources</td>
                                            <td style="min-width: 220px;">
                                                <div class="progress" style="height:20px;">
                                                    <div class="progress-bar bg-success"
                                                         role="progressbar"
                                                         style="width:@percent%;">
                                                        @percent%
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No unit progress available yet.</p>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card bg-dark border-secondary shadow-sm mb-4 h-100">
                <div class="card-header border-secondary">
                    <h5 class="text-white mb-0">My Current Loans</h5>
                </div>
                <div class="card-body text-white d-flex flex-column">
                    @if (Model.CurrentLoans.Any())
                    {
                        foreach (var loan in Model.CurrentLoans)
                        {
                            <div class="d-flex align-items-center mb-3 border-bottom pb-3">
                                @{
                                    var imagePath = string.IsNullOrWhiteSpace(loan.PhotoPath)
                                        ? "/images/alt-image.jpg"
                                        : (loan.PhotoPath.StartsWith("/images/")
                                            ? loan.PhotoPath
                                            : "/images/" + loan.PhotoPath);
                                }

                                <img src="@imagePath"
                                     alt="@loan.Title"
                                     class="rounded me-3"
                                     style="width:60px;height:80px;object-fit:cover;"
                                     onerror="this.onerror=null;this.src='/images/alt-image.jpg';" />
                                <div class="flex-grow-1">
                                    <h6 class="mb-1">@loan.Title</h6>
                                    <small class="text-muted d-block">Author: @loan.Author</small>
                                    <small class="text-muted d-block">Due: @loan.DueDate.ToString("dd MMM yyyy")</small>
                                    <small class="@(loan.DaysLeft < 0 ? "text-danger" : "text-success")">
                                        @(loan.DaysLeft < 0 ? $"{Math.Abs(loan.DaysLeft)} day(s) overdue" : $"{loan.DaysLeft} day(s) left")
                                    </small>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted mb-0">You have no active loans.</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card bg-dark border-secondary shadow-sm mb-4 h-100">
                <div class="card-header border-secondary">
                    <h5 class="text-white mb-0">My Top 5 Borrowed Books</h5>
                </div>
                <div class="card-body text-white d-flex flex-column">
                    @if (Model.TopBorrowedBooks.Any())
                    {
                        foreach (var book in Model.TopBorrowedBooks)
                        {
                            <div class="d-flex align-items-center mb-3 border-bottom pb-3">
                                @{
                                    var imagePath = string.IsNullOrWhiteSpace(book.PhotoPath)
                                        ? "/images/alt-image.jpg"
                                        : (book.PhotoPath.StartsWith("/images/")
                                            ? book.PhotoPath
                                            : "/images/" + book.PhotoPath);
                                }

                                <img src="@imagePath"
                                     alt="@book.Title"
                                     class="rounded me-3"
                                     style="width:60px;height:80px;object-fit:cover;"
                                     onerror="this.onerror=null;this.src='/images/alt-image.jpg';" />
                                <div class="flex-grow-1">
                                    <h6 class="mb-1">@book.Title</h6>
                                    <small class="text-muted d-block">Author: @book.Author</small>
                                    <small class="text-muted d-block">Category: @book.Category</small>
                                    <small class="text-primary fw-semibold">Borrowed @book.BorrowCount time(s)</small>
                                </div>

                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted mb-0">No borrowing data available yet.</p>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="row g-4 mt-1">
        <div class="col-12">
            <div class="card bg-dark border-secondary shadow-sm mb-4">
                <div class="card-header border-secondary d-flex justify-content-between align-items-center">
                    <h5 class="text-white mb-0">Recommended for You</h5>
                    <span class="badge bg-light text-dark">@Model.RecommendedBooks.Count</span>
                </div>

                <div class="card-body bg-dark">
                    @if (Model.RecommendedBooks.Any())
                    {
                        <div class="row g-3">
                            @foreach (var book in Model.RecommendedBooks)
                            {
                                <div class="col-12 col-sm-6 col-lg-4 col-xl-2">
                                    <div class="card h-100 border-secondary bg-black text-white shadow-sm">
                                        @{
                                            var imagePath = string.IsNullOrWhiteSpace(book.PhotoPath)
                                                ? "/images/alt-image.jpg"
                                                : (book.PhotoPath.StartsWith("/")
                                                    ? book.PhotoPath
                                                    : "/" + book.PhotoPath);
                                        }

                                        <img src="@imagePath"
                                             alt="@book.Title"
                                             class="card-img-top"
                                             style="height: 220px; object-fit: cover;"
                                             onerror="this.onerror=null;this.src='/images/alt-image.jpg';" />

                                        <div class="card-body d-flex flex-column">
                                            <h6 class="card-title mb-1">@book.Title</h6>
                                            <small class="text-muted d-block mb-1">@book.Author</small>

                                            <small class="text-info d-block mb-1">
                                                @(string.IsNullOrWhiteSpace(book.Category) ? "Uncategorized" : book.Category)
                                            </small>

                                            <small class="text-muted d-block mb-2">
                                                @(string.IsNullOrWhiteSpace(book.Department) ? "General" : book.Department)
                                            </small>

                                            <small class="text-warning d-block mb-3">@book.Reason</small>

                                            <div class="mt-auto d-flex justify-content-between align-items-center">
                                                <span class="badge @(book.AvailableCopies > 0 ? "bg-success" : "bg-danger")">
                                                    @(book.AvailableCopies > 0 ? "Available" : "Unavailable")
                                                </span>

                                                <a asp-controller="Book" asp-action="Index" class="btn btn-sm btn-outline-light">
                                                    View
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No recommendations available yet.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-1">
        <div class="col-lg-6">
            <div class="card bg-dark border-secondary shadow-sm mb-4 h-100">
                <div class="card-header border-secondary
                    text-white d-flex justify-content-between align-items-center">
                    <h5 class="text-white mb-0">Active Projects</h5>
                    <span class="badge bg-light text-dark">@Model.MyActiveProjects</span>
                </div>
                <div class="card-body text-white d-flex flex-column">
                    @if (Model.ActiveProjects.Any())
                    {
                        foreach (var project in Model.ActiveProjects)
                        {
                            <div class="border rounded p-3 mb-3">
                                <h6 class="fw-bold mb-1">@project.ProjectName</h6>
                                <p class="text-muted small mb-2">@project.Description</p>
                                <div class="small">
                                    <div><strong>Role:</strong> @project.Role</div>
                                    <div><strong>Members:</strong> @project.TeamMembers</div>
                                    <div><strong>Resources:</strong> @project.ResourceCount</div>
                                    <div><strong>Deadlines:</strong> @project.DeadlineCount</div>
                                    <div><strong>Unread Messages:</strong> @project.UnreadMessages</div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted mb-0">You are not in any active project yet.</p>
                    }
                </div>
            </div>
        </div>


        <div class="col-lg-6">
            <div class="card bg-dark border-secondary shadow-sm mb-4 h-100">
                <div class="card-header border-secondary
                    text-white d-flex justify-content-between align-items-center">
                    <h5 class="text-white mb-0">Upcoming Deadlines</h5>
                    <span class="badge bg-light text-dark">@Model.UpcomingDeadlines.Count</span>
                </div>
                <div class="card-body text-white d-flex flex-column">
                    @if (Model.UpcomingDeadlines.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var item in Model.UpcomingDeadlines)
                            {
                                <li class="list-group-item">
                                    <div class="fw-semibold">@item.DeadlineTitle</div>
                                    <div class="small text-muted">@item.ProjectName</div>
                                    <div class="small">
                                        Due: @item.DueDate.ToString("dd MMM yyyy")
                                        <span class="@(item.DaysLeft <= 2 ? "text-danger fw-bold" : "text-success")">
                                            (@item.DaysLeft day(s) left)
                                        </span>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No upcoming deadlines.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-1">
        <div class="col-lg-6">
            <div class="card bg-dark border-secondary shadow-sm mb-4 h-100">
                <div class="card-header border-secondary">
                    <h5 class="text-white mb-0">Due Soon Books</h5>
                </div>
                <div class="card-body text-white d-flex flex-column">
                    @if (Model.DueSoonBooks.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var item in Model.DueSoonBooks)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <span>@item.Title</span>
                                    <span class="badge bg-warning text-dark">@item.DueDate.ToString("dd MMM")</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No books are due soon.</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card bg-dark border-secondary shadow-sm mb-4 h-100">
                <div class="card-header border-secondary
                 text-white d-flex justify-content-between align-items-center">
                    <h5 class="text-white mb-0">Overdue Books</h5>
                    <span class="badge bg-light text-dark">@Model.UnreadProjectMessages unread messages</span>
                </div>
                <div class="card-body text-white d-flex flex-column">
                    @if (Model.OverdueBooks.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var item in Model.OverdueBooks)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <span>@item.Title</span>
                                    <span class="badge bg-danger">@item.DueDate.ToString("dd MMM")</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No overdue books.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>