@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}



@model IEnumerable<LibraryManagementSystem.Models.Book>
@{
    ViewData["Title"] = "Reports";
}

<div class="container-fluid px-3 mt-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-3 gap-2">
        <h2 class="mb-0"> Library Book Reports</h2>
        <button class="btn btn-outline-dark" data-bs-toggle="modal" data-bs-target="#filterModal">Filter</button>
    </div>

     @*Filter Modal*@ 
    <div class="modal fade" id="filterModal" tabindex="-1" aria-labelledby="filterModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="filterModalLabel">Filter Options</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form method="get" asp-action="Index" asp-controller="Report">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="filter" class="form-label">Select Report</label>
                            <select class="form-select" name="filter" id="filter">
                                <option value="">Select Filter</option>
                                <option value="NotReturned">Not Returned</option>
                                <option value="Overdue">Overdue</option>
                                <option value="MostBorrowed">Most Borrowed</option>
                                <option value="AvailableCopies">Available Copies</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-dark w-100">Apply Filter</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

     @*Responsive Table*@ 
    <div class="table-responsive">
        <table id="reportTable" class="table table-bordered table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>No</th>
                    <th>Title</th>
                    <th>Author</th>
                    <th>Total Copies</th>
                    <th>Available Copies</th>
                    <th>Times Borrowed</th>
                </tr>
            </thead>
            <tbody>
                @{ 
                    int count = 1;
                }
                @foreach (var book in Model)
                {
                    <tr>
                        <td>@count</td>
                        <td>@book.Title</td>
                        <td>@book.Author</td>
                        <td>@book.TotalCopies</td>
                        <td>@book.AvailableCopies</td>
                        <td>@(book.Loans?.Count() ?? 0)</td>
                    </tr>
                    count++;
                }
            </tbody>
        </table>
    </div>
</div>

 @*Initialize DataTables*@ 
<script>
    
    new DataTable('#reportTable', {
        layout: {
            topStart: {
                buttons: ['copy', 'csv', 'excel', 'pdf', 'print']
            }
        }
    });
</script>







